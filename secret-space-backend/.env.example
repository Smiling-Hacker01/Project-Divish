# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/secret_space"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — MUST be 32+ chars, unique values. Generate via: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase FCM
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# SMTP (for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@thesecretspace.app

# Face API
FACE_MATCH_THRESHOLD=0.5

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
